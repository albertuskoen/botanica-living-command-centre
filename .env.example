# ============================================================
# BOTANICA LIVING GROUP — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Vercel deployment:
#   Go to: Project Settings → Environment Variables
#   Add each key there. NEVER commit .env to git.
# ============================================================

# ── SUPABASE (required for cloud document storage + database) ────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── OCR FEATURE FLAG (set to any value to enable the Auto Extract button) ───
# This is NOT the secret key. It just tells the frontend that OCR is available.
# The actual secret key (OCR_SECRET_KEY) lives ONLY in Vercel server environment.
VITE_OCR_API_KEY=enabled

# ── SERVER-ONLY (Vercel only — NEVER prefix with VITE_) ─────────────────────
# Add this ONLY in Vercel dashboard, NOT in .env file
# OCR_SECRET_KEY=your_anthropic_or_openai_key_here
#
# To add in Vercel:
#   1. Go to vercel.com → your project → Settings → Environment Variables
#   2. Add: OCR_SECRET_KEY = sk-ant-xxxxxxxx  (or your OpenAI key)
#   3. Set scope to: Production + Preview (NOT exposed to browser)
#   4. Redeploy
