# ================================================================
# BOTANICA LIVING GROUP — ENVIRONMENT VARIABLES
# ================================================================
# Local development:
#   cp .env.example .env
#   Fill in values below, then: npm run dev
#
# Vercel deployment:
#   vercel.com → your project → Settings → Environment Variables
#   Add each VITE_ key with scope: Production + Preview + Development
#   Add OCR_SECRET_KEY with scope: Production only
# ================================================================

# ── SUPABASE ─────────────────────────────────────────────────────
# Where to find: supabase.com → project "Botanica Living"
#   → Project Settings (gear icon) → API

# Project URL (left column under "Project URL")
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key (under "Project API keys" → "anon public")
# This key is safe to expose in the browser — it has RLS protection
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_key_here

# ── OCR / AI EXTRACTION ───────────────────────────────────────────
# Feature flag: set to any non-empty value to enable the AI extraction
# pipeline. This tells the frontend that /api/extract is ready.
# The actual secret key below must be added separately in Vercel ONLY.
VITE_OCR_API_KEY=enabled

# ── SERVER-ONLY: NEVER add to .env or prefix with VITE_ ──────────
# This key is used ONLY by the Vercel serverless function /api/extract.js
# It NEVER reaches the browser. Add it in Vercel dashboard only.
#
#   Vercel → Settings → Environment Variables
#   Key:   OCR_SECRET_KEY
#   Value: sk-ant-api03-xxxx   (your Anthropic API key)
#   Scope: Production (only)
#
# OCR_SECRET_KEY=sk-ant-api03-your_key_here
